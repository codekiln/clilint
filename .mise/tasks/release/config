#!/usr/bin/env bash
#MISE description="Print the release-plz config for the current package major version"
set -euo pipefail

version=$(sed -n 's/^version = "\([^"]*\)"/\1/p' Cargo.toml | head -n 1)
major=${version%%.*}

if (( major < 1 )); then
  printf '%s\n' "release-plz.toml"
else
  printf '%s\n' "release-plz-post-1.toml"
fi
