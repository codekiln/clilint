#!/usr/bin/env bash
#MISE description="Test release-plz SemVer impact before and after 1.0"
set -euo pipefail

root=$(git rev-parse --show-toplevel)
fixture="$root/tests/fixtures/release-impact"
tmp_root=$(mktemp -d)
trap 'rm -rf "$tmp_root"' EXIT
case_index=0

run_case() {
  local current=$1
  local title=$2
  local expected=$3
  local config=$4
  local case_dir="$tmp_root/case-$case_index"
  case_index=$((case_index + 1))

  cp -R "$fixture" "$case_dir"
  sed -i.bak "s/version = \"0.0.0\"/version = \"$current\"/" "$case_dir/Cargo.toml"
  rm "$case_dir/Cargo.toml.bak"

  (
    cd "$case_dir"
    git init -q
    git config user.name "Release Impact Test"
    git config user.email "release-impact@example.invalid"
    git remote add origin https://github.com/codekiln/clilint
    git add .
    git commit -qm "initial fixture"
    git tag "v$current"

    sed -i.bak 's/MARKER: u8 = 0/MARKER: u8 = 1/' src/main.rs
    rm src/main.rs.bak
    git add src/main.rs
    git commit -qm "$title"

    release-plz update --config "$root/$config" --repo-url https://github.com/codekiln/clilint
  )

  local actual
  actual=$(sed -n 's/^version = "\([^"]*\)"/\1/p' "$case_dir/Cargo.toml" | head -n 1)
  if [[ "$actual" != "$expected" ]]; then
    printf 'expected %s -> %s for %s, got %s\n' "$current" "$expected" "$title" "$actual" >&2
    return 1
  fi
}

run_case 0.2.3 "✨ feat: add capability" 0.2.4 release-plz.toml
run_case 0.2.3 "🩹 fix: correct behavior" 0.2.4 release-plz.toml
run_case 0.2.3 "✨ feat!: replace behavior" 0.3.0 release-plz.toml
run_case 0.2.3 "📝 docs: clarify usage" 0.2.3 release-plz.toml
run_case 1.2.3 "✨ feat: add capability" 1.3.0 release-plz-post-1.toml
run_case 1.2.3 "🩹 fix: correct behavior" 1.2.4 release-plz-post-1.toml
run_case 1.2.3 "✨ feat!: replace behavior" 2.0.0 release-plz-post-1.toml
run_case 1.2.3 "📝 docs: clarify usage" 1.2.3 release-plz-post-1.toml

printf 'release impact tests passed\n'
