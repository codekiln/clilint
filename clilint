#!/usr/bin/env python3
"""Run clilint from a checkout without installing it.

Adds the bundled ``src/`` to the import path and dispatches to the CLI.
"""

import os
import sys

_HERE = os.path.dirname(os.path.abspath(__file__))
sys.path.insert(0, os.path.join(_HERE, "src"))

from clilint.cli import main  # noqa: E402

if __name__ == "__main__":
    raise SystemExit(main())
