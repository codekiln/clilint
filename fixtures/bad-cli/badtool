#!/usr/bin/env python3
"""badtool — a deliberately nonconformant example CLI used to exercise clilint.

It violates several rules on purpose: help goes to stderr and exits non-zero,
there is no usage/examples, no --version, unknown flags are accepted with a zero
exit code, errors are not reported, and it emits ANSI color even when piped.
Expect a low CLI Lint score.
"""

import sys

# Wrong: hardcoded color, emitted even when stdout is not a terminal.
BANNER = "\x1b[31mBADTOOL\x1b[0m running\n"


def main(argv=None) -> int:
    argv = sys.argv[1:] if argv is None else list(argv)

    if "--help" in argv:
        # Wrong: help to stderr, non-zero exit, no usage line, no examples.
        sys.stderr.write("badtool: no help available\n")
        return 1

    # Wrong: unknown flags accepted, colored output to stdout, nothing on
    # stderr, always exit 0 — failures are invisible.
    sys.stdout.write(BANNER)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
