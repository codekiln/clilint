#!/usr/bin/env python3
"""greet — a small, conformant example CLI used to exercise clilint.

It aims to pass every rule under the generated-cli profile: help and output on
stdout, errors on stderr, --version, --json, --no-input, no color when piped.
"""

import argparse
import json
import os
import sys

VERSION = "greet 1.2.0"


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="greet",
        description="Print a friendly greeting.",
        epilog=(
            "Examples:\n"
            "  greet Ada                Greet Ada\n"
            "  greet --json Ada         Emit the greeting as JSON\n"
            "  greet --no-input Ada     Run without prompting\n"
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument("name", nargs="?", default="world", help="who to greet")
    parser.add_argument("--version", "-V", action="version", version=VERSION)
    parser.add_argument("--json", action="store_true", help="emit the greeting as JSON")
    parser.add_argument("--no-input", action="store_true", help="never prompt; run unattended")
    parser.add_argument("--no-color", action="store_true", help="disable colored output")
    return parser


def main(argv=None) -> int:
    args = build_parser().parse_args(argv)
    use_color = sys.stdout.isatty() and not args.no_color and os.environ.get("NO_COLOR") is None

    if args.json:
        sys.stdout.write(json.dumps({"greeting": "hello", "name": args.name}) + "\n")
        return 0

    message = f"hello, {args.name}"
    if use_color:
        message = f"\x1b[32m{message}\x1b[0m"
    sys.stdout.write(message + "\n")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
