{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/codekiln/clilint/schemas/rule.schema.json",
  "title": "CLI Lint Rule",
  "description": "A single rule entry in the catalog files under rules/.",
  "type": "object",
  "required": ["id", "category", "title", "severity", "rationale", "remediation", "probe"],
  "additionalProperties": false,
  "properties": {
    "id": {"type": "string", "pattern": "^CLI-[A-Z]+-[0-9]+$", "description": "Stable rule identifier."},
    "category": {"type": "string", "description": "Rule group, e.g. 'help', 'output', 'error'."},
    "title": {"type": "string", "description": "One-line statement of the rule."},
    "severity": {"type": "string", "enum": ["error", "warn", "info"]},
    "weight": {"type": "number", "minimum": 0, "description": "Score weight; defaults from severity when omitted."},
    "rationale": {"type": "string", "description": "Why the rule exists."},
    "remediation": {"type": "string", "description": "How to satisfy the rule."},
    "source": {"type": "array", "items": {"type": "string"}, "description": "Where the guidance comes from."},
    "profiles": {"type": "array", "items": {"type": "string"}, "description": "Restrict the rule to these profiles; absent means all."},
    "probe": {"type": "string", "description": "Name of the probe module that evaluates this rule."}
  }
}
